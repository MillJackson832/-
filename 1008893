local RbxAnalyticsService = game:GetService("RbxAnalyticsService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local groupId = 843607581
 
local function getVerifyCode()
local cid = RbxAnalyticsService:GetClientId()
local s = string.split(cid, "-")
return s[1]..s[2]..s[3]..s[4]..s[5]
end
 
local isInGroup = false
pcall(function()
isInGroup = LocalPlayer:IsInGroup(groupId)
end)
if not isInGroup then
LocalPlayer:Kick("【验证失败】未加入指定Roblox群组\n群组ID："..groupId)
return
end
 
local code = getVerifyCode()
local whitelist
local success, err = pcall(function()
whitelist = game:HttpGet("https://raw.githubusercontent.com/MillJackson832/_/refs/heads/main/-.lua", false)
end)
 
if not success or not whitelist or whitelist == "" then
LocalPlayer:Kick("【白名单验证失败】获取列表失败\n原因："..tostring(err).."\n请检查网络重试")
return
end
 
if not string.find(whitelist, code) then
setclipboard(code)
LocalPlayer:Kick("【白名单验证失败】你的设备未在白名单内\n你的设备验证码："..code.."\n请联系管理员添加白名单")
return
end
